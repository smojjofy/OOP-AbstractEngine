' ============================================================================
' movement interface
' ============================================================================

interface IMovable <<interface>> {
  + getAcceleration(): float[]
  + setAcceleration(acceleration: float[]): void
  + getVelocity(): float[]
  + setVelocity(velocity: float[]): void
  + move(deltaTime: float): void
}

note right of IMovable
  **movement capability**

  physics properties:
  - acceleration: rate of velocity change
  - velocity: rate of position change
  - move(): integrates motion over time

  contract:
  - entities implement physics update
  - move() called each frame by manager
  - deltaTime for frame-independent motion

  typical implementation:
  {
    public void move(float deltaTime) {
      // integrate acceleration → velocity
      velocity[0] += acceleration[0] * deltaTime;
      velocity[1] += acceleration[1] * deltaTime;

      // integrate velocity → position
      float[] pos = transform.getPosition();
      pos[0] += velocity[0] * deltaTime;
      pos[1] += velocity[1] * deltaTime;
      transform.setPosition(pos);
    }
  }

  design notes:
  - entity controls its own movement logic
  - manager only calls move() and clamps bounds
  - supports custom movement behaviours
end note

' ============================================================================
' movement manager
' ============================================================================

class MovementManager <<manager>> {
  - movables: Array<IMovable>
  - boundariesEnabled: boolean
  - boundsMin: float[]
  - boundsMax: float[]
  + registerMovable(movable: IMovable): void
  + unregisterMovable(movable: IMovable): void
  + setBoundariesEnabled(enabled: boolean): void
  + setWorldBounds(min: float[], max: float[]): void
  # onUpdate(deltaTime: float): void
  - clampToBounds(transformable: ITransformable): void
}

note left of MovementManager
  **movement orchestrator**

  responsibilities:
  - manages collection of movable entities
  - calls move() on each entity per frame
  - optionally enforces world boundaries

  update cycle:
  1. for each registered IMovable:
     a. call movable.move(deltaTime)
     b. if boundaries enabled:
        - clamp position to world bounds

  boundary enforcement:
  - optional feature (disabled by default)
  - prevents entities from leaving world
  - clamping algorithm:
    * ensure position >= boundsMin
    * ensure position + size <= boundsMax

  registration:
  - entities register/unregister dynamically
  - typically registered on spawn
  - unregistered on despawn

  design notes:
  - extends UpdatableManager (lifecycle + update)
  - dimension-agnostic (works with 2d/3d)
  - no physics simulation (entities control motion)
end note

' ============================================================================
' manager base classes (from engine core)
' ============================================================================

abstract Manager <<abstract>> {
  - initialised: boolean
  + init(): void {final}
  + shutdown(): void {final}
  # onInit(): void
  # onShutdown(): void
  + isInitialised(): boolean
}

abstract UpdatableManager <<abstract>> {
  + update(deltaTime: float): void {final}
  # onUpdate(deltaTime: float): void {abstract}
}

' ============================================================================
' external dependencies
' ============================================================================

interface ITransformable <<interface>> {
  + getTransform(): ITransform
}

interface ITransform <<interface>> {
  + getPosition(): float[]
  + setPosition(position: float[]): void
  + getSize(): float[]
  + setSize(size: float[]): void
  + getDimensions(): int
}

class "Array<T>" as Array <<external>> {
  + add(value: T): void
  + remove(value: T): boolean
  + iterator(): Iterator<T>
}

' ============================================================================
' relationships
' ============================================================================

MovementManager --|> UpdatableManager : extends
MovementManager o-- "many" IMovable : manages
MovementManager ..> ITransformable : uses
MovementManager ..> ITransform : uses
MovementManager ..> Array : uses

UpdatableManager --|> Manager : extends

IMovable ..> ITransformable : requires

' ============================================================================
' usage example
' ============================================================================

note as UsageExample
  **usage example**

  {
    // create movement manager
    MovementManager movementManager = new MovementManager();
    movementManager.init();

    // configure world boundaries
    movementManager.setBoundariesEnabled(true);
    movementManager.setWorldBounds(
      new float[]{0, 0},              // min (x, y)
      new float[]{800, 600}            // max (x, y)
    );

    // create movable entity
    class Player extends Entity
        implements IMovable, ITransformable {

      private Transform2D transform = new Transform2D();
      private float[] velocity = new float[2];
      private float[] acceleration = new float[2];

      public void move(float deltaTime) {
        // integrate acceleration
        velocity[0] += acceleration[0] * deltaTime;
        velocity[1] += acceleration[1] * deltaTime;

        // integrate velocity
        float[] pos = transform.getPosition();
        pos[0] += velocity[0] * deltaTime;
        pos[1] += velocity[1] * deltaTime;
        transform.setPosition(pos);
      }

      // getters/setters...
    }

    // register entity
    Player player = new Player();
    movementManager.registerMovable(player);

    // game loop
    while (running) {
      float deltaTime = getDeltaTime();
      movementManager.update(deltaTime);
      // player.move() called automatically
      // position clamped to bounds
    }

    // cleanup
    movementManager.unregisterMovable(player);
    movementManager.shutdown();
  }
end note

' ============================================================================
' boundary clamping algorithm
' ============================================================================

note as BoundaryAlgorithm
  **boundary clamping algorithm**

  {
    private void clampToBounds(ITransformable transformable) {
      if (!boundariesEnabled) return;

      ITransform transform = transformable.getTransform();
      float[] pos = transform.getPosition();
      float[] size = transform.getSize();
      int dims = transform.getDimensions();

      // clamp each dimension
      for (int i = 0; i < dims; i++) {
        // clamp minimum
        if (pos[i] < boundsMin[i]) {
          pos[i] = boundsMin[i];
        }

        // clamp maximum
        if (pos[i] + size[i] > boundsMax[i]) {
          pos[i] = boundsMax[i] - size[i];
        }
      }

      transform.setPosition(pos);
    }
  }

  characteristics:
  - dimension-agnostic (works for 2d/3d)
  - considers entity size (not just position)
  - clamps to inclusive bounds
  - preserves entity within world
end note

' ============================================================================
' design patterns summary
' ============================================================================

note as DesignPatterns
  **design patterns in movement system**

  1. **observer pattern variant**
     - manager observes registered movables
     - calls move() each frame
     - entities notify via state change

  2. **strategy pattern**
     - IMovable.move() is strategy
     - each entity implements own movement
     - flexible movement behaviours

  3. **template method pattern**
     - UpdatableManager.update() calls onUpdate()
     - onUpdate() processes all movables
     - consistent update lifecycle

  4. **optional feature pattern**
     - boundary clamping is optional
     - enabled/disabled at runtime
     - no performance cost when disabled

  benefits:
  - simple physics integration
  - flexible entity movement
  - optional boundary enforcement
  - dimension-agnostic design
  - testable movement logic
end note

@enduml
