' ============================================================================
' action identifier
' ============================================================================

class ActionId <<concrete>> {
  - id: String
  + {static} NONE: ActionId
  + ActionId(id: String)
  + getId(): String
  + equals(obj: Object): boolean
  + hashCode(): int
  + toString(): String
}

note right of ActionId
  **logical action identifier**

  purpose:
  - represents logical game actions
  - decouples actions from physical inputs
  - type-safe action references

  examples:
  - MOVE_UP, MOVE_DOWN, MOVE_LEFT, MOVE_RIGHT
  - JUMP, SHOOT, INTERACT
  - PAUSE, MENU_SELECT

  design:
  - immutable value object
  - proper equals/hashCode for maps
  - static NONE for null-object pattern

  usage:
  {
    ActionId moveUp = new ActionId("MOVE_UP");
    ActionId jump = new ActionId("JUMP");

    // or define constants
    class Actions {
      static final ActionId MOVE_UP =
          new ActionId("MOVE_UP");
    }
  }
end note

' ============================================================================
' input state enumeration
' ============================================================================

enum InputState <<enum>> {
  PRESSED
  HELD
  RELEASED
}

note left of InputState
  **input state lifecycle**

  states:
  - PRESSED: just pressed this frame
  - HELD: held down (not just pressed)
  - RELEASED: just released this frame

  state transitions:
  - not pressed → PRESSED (first frame)
  - PRESSED → HELD (subsequent frames)
  - HELD → RELEASED (release frame)
  - RELEASED → not pressed (next frame)

  usage:
  {
    // single-shot actions (menus, jumps)
    if (input.getActionState(JUMP) == PRESSED) {
      performJump();
    }

    // continuous actions (movement)
    if (input.isActionActive(MOVE_LEFT)) {
      moveLeft(deltaTime);
    }
  }
end note

' ============================================================================
' input event base class
' ============================================================================

abstract InputEvent <<abstract>> {
  - actionId: ActionId
  - timestamp: long
  # InputEvent(actionId: ActionId, timestamp: long)
  + getActionId(): ActionId
  + getTimestamp(): long
}

note bottom of InputEvent
  **input event base class**

  purpose:
  - represents input events
  - tracks action and timestamp
  - extensible for specific event types

  potential subclasses:
  - KeyPressEvent
  - MouseButtonEvent
  - AxisInputEvent

  design:
  - abstract base class
  - protected constructor
  - immutable event data
end note

' ============================================================================
' input query interface
' ============================================================================

interface IInputQuery <<interface>> {
  + isActionActive(actionId: ActionId): boolean
  + getActionState(actionId: ActionId): InputState
}

note right of IInputQuery
  **input query abstraction**

  contract:
  - isActionActive(): true if PRESSED or HELD
  - getActionState(): precise state information

  used by:
  - scenes (game logic)
  - entities (player controllers)
  - ui systems

  design benefits:
  - read-only input access
  - decouples queries from management
  - testable with mock inputs

  via SceneContext:
  {
    void update(float dt, SceneContext ctx) {
      IInputQuery input = ctx.input();
      if (input.isActionActive(MOVE_UP)) {
        player.moveUp();
      }
    }
  }
end note

' ============================================================================
' input mapping
' ============================================================================

class InputMapping <<concrete>> {
  - keyBindings: ObjectMap<Integer, ActionId>
  - buttonBindings: ObjectMap<Integer, ActionId>
  + InputMapping()
  + resetToDefaults(): void
  + bindKey(keyCode: int, actionId: ActionId): void
  + bindButton(buttonCode: int, actionId: ActionId): void
  + getActionForKey(keyCode: int): ActionId
  + getActionForButton(buttonCode: int): ActionId
  + getKeysForAction(actionId: ActionId): Array<Integer>
  + getButtonsForAction(actionId: ActionId): Array<Integer>
  + getAllActions(): ObjectSet<ActionId>
}

note left of InputMapping
  **input remapping system**

  responsibilities:
  - maps physical inputs to logical actions
  - supports rebindable controls
  - bidirectional lookup

  mapping structure:
  - keyBindings: key code → action id
  - buttonBindings: mouse button → action id

  features:
  - resetToDefaults(): restore default bindings
  - bindKey/bindButton(): rebind controls
  - reverse lookup: getKeysForAction()

  usage:
  {
    InputMapping mapping = new InputMapping();

    // set up bindings
    mapping.bindKey(Input.Keys.W, MOVE_UP);
    mapping.bindKey(Input.Keys.S, MOVE_DOWN);
    mapping.bindKey(Input.Keys.SPACE, JUMP);

    // query bindings
    ActionId action = mapping.getActionForKey(
        Input.Keys.W);  // returns MOVE_UP

    // reverse lookup
    Array<Integer> keys = mapping.getKeysForAction(
        MOVE_UP);  // returns [W]
  }

  design notes:
  - mutable (for runtime rebinding)
  - supports multiple keys per action
  - libgdx key codes
end note

' ============================================================================
' input output manager
' ============================================================================

class InputOutputManager <<manager>> {
  - inputMapping: InputMapping
  - inputEnabled: boolean
  - actionStates: ObjectMap<ActionId, InputState>
  - previousDown: ObjectMap<ActionId, Boolean>
  # onUpdate(deltaTime: float): void
  + isActionActive(actionId: ActionId): boolean
  + getActionState(actionId: ActionId): InputState
  + getInputMapping(): InputMapping
  + setInputEnabled(enabled: boolean): void
  - getBoundActions(): ObjectSet<ActionId>
  - isPhysicallyDown(action: ActionId): boolean
}

note bottom of InputOutputManager
  **input state manager**

  responsibilities:
  - polls physical inputs each frame
  - updates action states
  - provides query interface
  - manages input mapping

  update cycle (onUpdate):
  1. for each bound action:
     a. check if physically down (via mapping)
     b. compare with previous frame state
     c. update InputState:
        - not down → down: PRESSED
        - down → down: HELD
        - down → not down: RELEASED

  state tracking:
  - actionStates: current frame state
  - previousDown: last frame down state
  - enables PRESSED/HELD/RELEASED detection

  features:
  - inputEnabled flag (disable during menus)
  - exposes mapping for rebinding
  - implements IInputQuery interface

  design notes:
  - extends UpdatableManager (lifecycle + update)
  - owns InputMapping instance
  - stateful (tracks frame-to-frame changes)
end note

