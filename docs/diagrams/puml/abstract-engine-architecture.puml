@startuml abstract-engine-architecture

' ============================================================================
' abstract engine architecture - complete system diagram
' ============================================================================
' this diagram shows the complete architecture of the abstract engine package
' includes: 8 packages, 32 classes/interfaces
' note: external libgdx types referenced in method signatures only
' ============================================================================

' styling and colour scheme
skinparam packageStyle rectangle
skinparam classBackgroundColor<<interface>> #E3F2FD
skinparam classBackgroundColor<<abstract>> #FFF9C4
skinparam classBackgroundColor<<manager>> #FFE0B2
skinparam classBackgroundColor<<concrete>> #E8F5E9
skinparam classBackgroundColor<<enum>> #F5F5F5
skinparam classBackgroundColor<<external>> #EEEEEE
skinparam classBorderColor #424242
skinparam packageBorderColor #1976D2
skinparam arrowColor #424242
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80

' ============================================================================
' package 1: engine core - orchestration and manager hierarchy
' ============================================================================
package "engine" <<Rectangle>> {

  interface IManager <<interface>> {
    + init(): void
    + shutdown(): void
  }

  interface IUpdatable <<interface>> {
    + update(deltaTime: float): void
  }

  abstract Manager <<abstract>> {
    - initialised: boolean
    + init(): void {final}
    + shutdown(): void {final}
    # onInit(): void
    # onShutdown(): void
    + isInitialised(): boolean
  }

  abstract UpdatableManager <<abstract>> {
    + update(deltaTime: float): void {final}
    # onUpdate(deltaTime: float): void {abstract}
  }

  class Engine <<concrete>> {
    - managers: Array<IManager>
    - updatables: Array<IUpdatable>
    - renderManager: RenderManager
    + registerManager(manager: IManager): void
    + registerUpdatable(updatable: IUpdatable): void
    + setRenderManager(renderManager: RenderManager): void
    + init(): void
    + update(deltaTime: float): void
    + render(): void
    + shutdown(): void
  }

  class Settings <<concrete>> {
    + {static} WINDOW_WIDTH: int = 640
    + {static} WINDOW_HEIGHT: int = 480
  }

  note right of Manager
    **template method pattern**
    - base class provides lifecycle hooks
    - subclasses implement onInit/onShutdown
    - final methods ensure proper sequencing
  end note
}

' ============================================================================
' package 2: entity system - entity lifecycle and management
' ============================================================================
package "entity" <<Rectangle>> {

  abstract Entity <<abstract>> {
    - id: UUID
    - active: boolean
    # Entity()
    + getId(): UUID
    + isActive(): boolean
    + setActive(active: boolean): void
  }

  interface EntityFactory <<interface>> {
    + create(): Entity
  }

  interface IEntityRepository <<interface>> {
    + getEntity(id: UUID): Entity
    + getAllEntityIds(): Iterable<UUID>
  }

  interface IEntityMutator <<interface>> {
    + createEntity(factory: EntityFactory): Entity
    + updateEntity(id: UUID, active: boolean): void
    + removeEntity(id: UUID): void
  }

  class EntityManager <<manager>> {
    - entities: Array<Entity>
    + createEntity(factory: EntityFactory): Entity
    + updateEntity(id: UUID, active: boolean): void
    + removeEntity(id: UUID): void
    + getEntity(id: UUID): Entity
    + getAllEntityIds(): Array<UUID>
    + toString(): String
  }

  note left of IEntityRepository
    **interface segregation principle**
    - IEntityRepository: read-only access
    - IEntityMutator: write operations
    - clients depend only on needed operations
  end note
}

' ============================================================================
' package 3: transform system - spatial transformations
' ============================================================================
package "transform" <<Rectangle>> {

  interface ITransform <<interface>> {
    + getPosition(): float[]
    + setPosition(position: float[]): void
    + getSize(): float[]
    + setSize(size: float[]): void
    + getDimensions(): int
  }

  interface ITransformable <<interface>> {
    + getTransform(): ITransform
  }

  note bottom of ITransform
    **spatial abstraction**
    - dimension-agnostic design
    - supports 2d/3d via getDimensions()
    - position and size as float arrays
  end note
}

' ============================================================================
' package 4: render system - rendering pipeline
' ============================================================================
package "render" <<Rectangle>> {

  interface IRenderable <<interface>> {
    + getAssetPath(): String
  }

  interface IRenderItem <<interface>> {
  }

  interface IRenderQueue <<interface>> {
    + queue(item: IRenderItem): void
    + clear(): void
    + items(): Iterable<IRenderItem>
  }

  class RenderQueue <<concrete>> {
    - items: Array<IRenderItem>
    + queue(item: IRenderItem): void
    + clear(): void
    + items(): Array<IRenderItem>
  }

  class RenderManager <<manager>> {
    - batch: SpriteBatch
    - shapeRenderer: ShapeRenderer
    - assetManager: AssetManager
    - queue: RenderQueue
    # onInit(): void
    # onShutdown(): void
    + getRenderQueue(): IRenderQueue
    + render(): void
    - draw(item: IRenderItem): void
    - drawProcedural(item: IRenderItem): void
  }

  note right of IRenderItem
    **composition over inheritance**
    - combines IRenderable + ITransformable
    - entities implement both capabilities
    - flexible composition of behaviours
  end note
}

' ============================================================================
' package 5: movement system - physics and movement
' ============================================================================
package "movement" <<Rectangle>> {

  interface IMovable <<interface>> {
    + getAcceleration(): float[]
    + setAcceleration(acceleration: float[]): void
    + getVelocity(): float[]
    + setVelocity(velocity: float[]): void
    + move(deltaTime: float): void
  }

  class MovementManager <<manager>> {
    - movables: Array<IMovable>
    - boundariesEnabled: boolean
    - boundsMin: float[]
    - boundsMax: float[]
    + registerMovable(movable: IMovable): void
    + unregisterMovable(movable: IMovable): void
    + setBoundariesEnabled(enabled: boolean): void
    + setWorldBounds(min: float[], max: float[]): void
    # onUpdate(deltaTime: float): void
    - clampToBounds(transformable: ITransformable): void
  }

  note bottom of MovementManager
    **optional boundary enforcement**
    - manages collection of IMovable entities
    - optional world bounds clamping
    - integrates with transform system
  end note
}

' ============================================================================
' package 6: collision system - collision detection and resolution
' ============================================================================
package "collision" <<Rectangle>> {

  interface ICollidable <<interface>> {
    + getBounds(): Rectangle
    + onCollision(other: ICollidable): void
  }

  class CollisionDetector <<concrete>> {
    + checkCollision(a: ICollidable, b: ICollidable): boolean
  }

  class CollisionManager <<manager>> {
    - collidables: Array<ICollidable>
    - detector: CollisionDetector
    + registerCollidable(collidable: ICollidable): void
    + unregisterCollidable(collidable: ICollidable): void
    # onUpdate(deltaTime: float): void
    - detectAndResolve(): void
  }

  note right of ICollidable
    **observer pattern**
    - onCollision callback for response
    - entities decide their own behaviour
    - decoupled collision response
  end note
}

' ============================================================================
' package 7: input system - input handling and mapping
' ============================================================================
package "input" <<Rectangle>> {

  class ActionId <<concrete>> {
    - id: String
    + {static} NONE: ActionId
    + ActionId(id: String)
    + getId(): String
    + equals(obj: Object): boolean
    + hashCode(): int
    + toString(): String
  }

  enum InputState <<enum>> {
    PRESSED
    HELD
    RELEASED
  }

  abstract InputEvent <<abstract>> {
    - actionId: ActionId
    - timestamp: long
    # InputEvent(actionId: ActionId, timestamp: long)
    + getActionId(): ActionId
    + getTimestamp(): long
  }

  interface IInputQuery <<interface>> {
    + isActionActive(actionId: ActionId): boolean
    + getActionState(actionId: ActionId): InputState
  }

  class InputMapping <<concrete>> {
    - keyBindings: ObjectMap<Integer, ActionId>
    - buttonBindings: ObjectMap<Integer, ActionId>
    + InputMapping()
    + resetToDefaults(): void
    + bindKey(keyCode: int, actionId: ActionId): void
    + bindButton(buttonCode: int, actionId: ActionId): void
    + getActionForKey(keyCode: int): ActionId
    + getActionForButton(buttonCode: int): ActionId
    + getKeysForAction(actionId: ActionId): Array<Integer>
    + getButtonsForAction(actionId: ActionId): Array<Integer>
    + getAllActions(): ObjectSet<ActionId>
  }

  class InputOutputManager <<manager>> {
    - inputMapping: InputMapping
    - inputEnabled: boolean
    - actionStates: ObjectMap<ActionId, InputState>
    - previousDown: ObjectMap<ActionId, Boolean>
    # onUpdate(deltaTime: float): void
    + isActionActive(actionId: ActionId): boolean
    + getActionState(actionId: ActionId): InputState
    + getInputMapping(): InputMapping
    + setInputEnabled(enabled: boolean): void
    - getBoundActions(): ObjectSet<ActionId>
    - isPhysicallyDown(action: ActionId): boolean
  }

  note left of InputMapping
    **input abstraction**
    - maps physical inputs to logical actions
    - rebindable controls
    - supports keyboard and mouse
  end note
}

' ============================================================================
' package 8: scene system - scene management and transitions
' ============================================================================
package "scene" <<Rectangle>> {

  interface SceneContext <<interface>> {
    + entities(): IEntityRepository
    + renderQueue(): IRenderQueue
    + input(): IInputQuery
    + sceneManager(): SceneManager
  }

  abstract Scene <<abstract>> {
    # name: String
    # paused: boolean
    + {abstract} onEnter(context: SceneContext): void
    + {abstract} onExit(context: SceneContext): void
    + {abstract} update(deltaTime: float, context: SceneContext): void
    + {abstract} submitRenderable(context: SceneContext): void
    + getName(): String
    + isPaused(): boolean
    + setPaused(paused: boolean): void
  }

  class SceneManager <<manager>> {
    - scenes: ObjectMap<String, Scene>
    - currentKey: String
    - pendingKey: String
    - context: SceneContext
    - entityRepository: IEntityRepository
    - renderQueue: IRenderQueue
    - inputQuery: IInputQuery
    + SceneManager(entityRepository: IEntityRepository, renderQueue: IRenderQueue, inputQuery: IInputQuery)
    # onInit(): void
    # onShutdown(): void
    + registerScene(scene: Scene): void
    + setInitialScene(key: String): void
    + requestChange(key: String): void
    + getCurrentScene(): Scene
    + getScene(key: String): Scene
    + getSceneKeys(): Iterable<String>
    # onUpdate(deltaTime: float): void
  }

  note right of SceneManager
    **deferred state changes**
    - pendingKey for safe transitions
    - prevents mid-update scene changes
    - dependency injection via constructor
  end note
}

