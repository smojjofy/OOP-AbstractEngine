' ============================================================================
' usage example
' ============================================================================

note as UsageExample
  **usage example**

  {
    // create scene manager with dependencies
    EntityManager entityManager = new EntityManager();
    RenderManager renderManager = new RenderManager();
    InputOutputManager inputManager = new InputOutputManager();

    SceneManager sceneManager = new SceneManager(
      entityManager,  // entity repository
      renderManager.getRenderQueue(),  // render queue
      inputManager    // input query
    );

    sceneManager.init();

    // define scenes
    class MenuScene extends Scene {
      public void onEnter(SceneContext ctx) {
        System.out.println("entering menu");
      }

      public void onExit(SceneContext ctx) {
        System.out.println("exiting menu");
      }

      public void update(float dt, SceneContext ctx) {
        if (ctx.input().isActionActive(START)) {
          ctx.sceneManager().requestChange("game");
        }
      }

      public void submitRenderable(SceneContext ctx) {
        // queue menu graphics
      }
    }

    class GameScene extends Scene {
      public void onEnter(SceneContext ctx) {
        // spawn player, enemies, etc.
        Entity player = ctx.entities().createEntity(
            () -> new PlayerEntity());
      }

      public void onExit(SceneContext ctx) {
        // cleanup game entities
      }

      public void update(float dt, SceneContext ctx) {
        if (ctx.input().isActionActive(PAUSE)) {
          ctx.sceneManager().requestChange("pause");
        }
      }

      public void submitRenderable(SceneContext ctx) {
        // entities queue themselves
      }
    }

    // register scenes
    sceneManager.registerScene(new MenuScene());
    sceneManager.registerScene(new GameScene());
    sceneManager.setInitialScene("menu");

    // game loop
    while (running) {
      float deltaTime = getDeltaTime();
      sceneManager.update(deltaTime);
    }

    sceneManager.shutdown();
  }
end note

' ============================================================================
' transition algorithm
' ============================================================================

note as TransitionAlgorithm
  **scene transition algorithm**

  {
    protected void onUpdate(float deltaTime) {
      // handle pending scene change
      if (pendingKey != null) {
        Scene current = getCurrentScene();
        Scene next = getScene(pendingKey);

        // exit current scene
        if (current != null) {
          current.onExit(context);
        }

        // switch scenes
        currentKey = pendingKey;
        pendingKey = null;

        // enter new scene
        if (next != null) {
          next.onEnter(context);
        }
      }

      // update current scene
      Scene current = getCurrentScene();
      if (current != null && !current.isPaused()) {
        current.update(deltaTime, context);
        current.submitRenderable(context);
      }
    }
  }

  characteristics:
  - deferred transitions (safe)
  - respects pause state
  - calls lifecycle hooks
  - null-safe
end note

' ============================================================================
' design patterns summary
' ============================================================================

note as DesignPatterns
  **design patterns in scene system**

  1. **dependency injection**
     - SceneManager constructor injection
     - SceneContext provides dependencies
     - testable and decoupled

  2. **template method pattern**
     - Scene abstract base class
     - lifecycle hooks (onEnter/onExit/update)
     - consistent scene interface

  3. **deferred state changes**
     - pendingKey for safe transitions
     - prevents mid-update scene changes
     - consistent state management

  4. **facade pattern**
     - SceneContext as facade
     - hides engine complexity
     - controlled system access

  5. **registry pattern**
     - scenes stored in ObjectMap
     - keyed by string identifier
     - dynamic scene lookup

  benefits:
  - safe scene transitions
  - testable scene logic
  - dependency injection
  - decoupled from engine
  - flexible scene management
end note

@enduml
