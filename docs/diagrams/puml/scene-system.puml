' ============================================================================
' scene context interface
' ============================================================================

interface SceneContext <<interface>> {
  + entities(): IEntityRepository
  + renderQueue(): IRenderQueue
  + input(): IInputQuery
  + sceneManager(): SceneManager
}

note right of SceneContext
  **dependency injection interface**

  purpose:
  - provides scenes access to engine systems
  - dependency injection pattern
  - read-only system access

  provided systems:
  - entities(): query entities
  - renderQueue(): submit renderables
  - input(): query input state
  - sceneManager(): request scene transitions

  design benefits:
  - testable (mock context for tests)
  - controlled access (read-only interfaces)
  - decoupled scenes from engine internals

  usage in scene:
  {
    void update(float dt, SceneContext ctx) {
      // query entities
      IEntityRepository entities = ctx.entities();

      // submit to render queue
      IRenderQueue queue = ctx.renderQueue();
      queue.queue(sprite);

      // check input
      if (ctx.input().isActionActive(PAUSE)) {
        ctx.sceneManager().requestChange("pause");
      }
    }
  }
end note

' ============================================================================
' scene base class
' ============================================================================

abstract Scene <<abstract>> {
  # name: String
  # paused: boolean
  + {abstract} onEnter(context: SceneContext): void
  + {abstract} onExit(context: SceneContext): void
  + {abstract} update(deltaTime: float, context: SceneContext): void
  + {abstract} submitRenderable(context: SceneContext): void
  + getName(): String
  + isPaused(): boolean
  + setPaused(paused: boolean): void
}

note left of Scene
  **scene base class**

  lifecycle hooks:
  - onEnter(): called when scene becomes active
  - onExit(): called when leaving scene
  - update(): called each frame
  - submitRenderable(): queue rendering

  responsibilities:
  - manage scene-specific entities
  - handle scene logic and input
  - submit renderables to queue
  - request scene transitions

  typical implementation:
  {
    class MenuScene extends Scene {
      public void onEnter(SceneContext ctx) {
        // create menu entities
        // set up ui
      }

      public void onExit(SceneContext ctx) {
        // cleanup menu entities
        // remove from managers
      }

      public void update(float dt, SceneContext ctx) {
        if (ctx.input().isActionActive(SELECT)) {
          ctx.sceneManager().requestChange("game");
        }
      }

      public void submitRenderable(SceneContext ctx) {
        // queue menu sprites
        ctx.renderQueue().queue(background);
        ctx.renderQueue().queue(buttons);
      }
    }
  }

  design notes:
  - abstract base class
  - template for concrete scenes
  - receives context for all operations
end note

' ============================================================================
' scene manager
' ============================================================================

class SceneManager <<manager>> {
  - scenes: ObjectMap<String, Scene>
  - currentKey: String
  - pendingKey: String
  - context: SceneContext
  - entityRepository: IEntityRepository
  - renderQueue: IRenderQueue
  - inputQuery: IInputQuery
  + SceneManager(entityRepository: IEntityRepository, renderQueue: IRenderQueue, inputQuery: IInputQuery)
  # onInit(): void
  # onShutdown(): void
  + registerScene(scene: Scene): void
  + setInitialScene(key: String): void
  + requestChange(key: String): void
  + getCurrentScene(): Scene
  + getScene(key: String): Scene
  + getSceneKeys(): Iterable<String>
  # onUpdate(deltaTime: float): void
}

note bottom of SceneManager
  **scene orchestrator**

  responsibilities:
  - manages collection of registered scenes
  - handles scene transitions safely
  - provides SceneContext to scenes
  - calls scene lifecycle hooks

  constructor injection:
  - receives IEntityRepository
  - receives IRenderQueue
  - receives IInputQuery
  - creates SceneContext from these

  scene registration:
  - registerScene(): add scene to registry
  - setInitialScene(): set starting scene
  - scenes identified by string key

  safe transitions:
  - requestChange(): sets pendingKey
  - actual transition in onUpdate()
  - prevents mid-update scene changes

  update cycle:
  1. check for pending scene change
  2. if pending:
     a. call currentScene.onExit(context)
     b. switch to pending scene
     c. call newScene.onEnter(context)
     d. clear pending
  3. call currentScene.update(deltaTime, context)
  4. call currentScene.submitRenderable(context)

  design notes:
  - extends UpdatableManager (lifecycle + update)
  - owns SceneContext instance
  - deferred state changes pattern
end note

