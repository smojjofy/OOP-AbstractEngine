note right of EntityManager
  **manager implementations**

  non-updatable managers:
  - EntityManager (manages entities)
  - RenderManager (rendering pipeline)

  updatable managers:
  - MovementManager (physics updates)
  - CollisionManager (collision detection)
  - InputOutputManager (input polling)
  - SceneManager (scene transitions)

  see individual package diagrams
  for detailed implementations
end note

' ============================================================================
' usage example
' ============================================================================

note as UsageExample
  **usage example**

  {
    // create engine
    Engine engine = new Engine();

    // create and register managers
    EntityManager entityManager = new EntityManager();
    RenderManager renderManager = new RenderManager();
    MovementManager movementManager = new MovementManager();
    CollisionManager collisionManager = new CollisionManager();
    InputOutputManager inputManager = new InputOutputManager();
    SceneManager sceneManager = new SceneManager(
      entityManager,
      renderManager.getRenderQueue(),
      inputManager
    );

    // register with engine
    engine.registerManager(entityManager);
    engine.registerManager(renderManager);
    engine.registerManager(movementManager);
    engine.registerManager(collisionManager);
    engine.registerManager(inputManager);
    engine.registerManager(sceneManager);

    // register updatables
    engine.registerUpdatable(movementManager);
    engine.registerUpdatable(collisionManager);
    engine.registerUpdatable(inputManager);
    engine.registerUpdatable(sceneManager);

    // set render manager
    engine.setRenderManager(renderManager);

    // initialise all subsystems
    engine.init();

    // game loop
    while (running) {
      float deltaTime = getDeltaTime();
      engine.update(deltaTime);
      engine.render();
    }

    // cleanup
    engine.shutdown();
  }
end note

@enduml
