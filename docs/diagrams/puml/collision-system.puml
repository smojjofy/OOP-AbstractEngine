@startuml collision-system

' ============================================================================
' collision system package - collision detection and resolution
' ============================================================================
' this diagram focuses on the collision subsystem, showing how entities
' with collision capabilities are detected and resolved each frame using
' a simple observer pattern for collision responses
' ============================================================================

' styling
skinparam classBackgroundColor<<interface>> #E3F2FD
skinparam classBackgroundColor<<abstract>> #FFF9C4
skinparam classBackgroundColor<<manager>> #FFE0B2
skinparam classBackgroundColor<<concrete>> #E8F5E9
skinparam classBackgroundColor<<external>> #EEEEEE
